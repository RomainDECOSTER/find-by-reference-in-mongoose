{
  "name": "find-by-reference-in-mongoose",
  "version": "1.0.4",
  "description": "Add Mongoose support for finding in reference",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --clean -d dist && tsc --emitDeclarationOnly --outDir dist && cp dist/index.d.ts dist/index.d.mts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RomainDECOSTER/find-by-reference-in-mongoose.git"
  },
  "bugs": {
    "url": "https://github.com/RomainDECOSTER/find-by-reference-in-mongoose/issues"
  },
  "author": "RomainDECOSTER",
  "keywords": [
    "mongoose",
    "reference",
    "ref",
    "objectid",
    "mongodb"
  ],
  "license": "MIT",
  "devDependencies": {
    "mongoose": "^9.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "mongoose": "^8.0.0 || ^9.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
